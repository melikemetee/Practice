# STEP 1: Load and Explore the Built-in Iris Dataset
# The dataset contains 150 records of 3 different iris flower species
data(iris)

print("📊 First 6 rows of the Iris Dataset:")
print(head(iris))
print(separator <- paste(rep("-", 50), collapse = ""))

# STEP 2: Descriptive Statistical Data Analysis
# Checking the structural components and summary of the data
print("📈 Summary Statistics Per Feature:")
print(summary(iris))
print(separator)

# Calculating the mean Sepal Length grouped by each Species
print("🧪 Average Sepal Length per Flower Species:")
species_mean <- aggregate(Sepal.Length ~ Species, data = iris, FUN = mean)
print(species_mean)
print(separator)

# STEP 3: Data Visualization
# Creating a Scatter Plot to classify species by Sepal Length and Width
# This represents data analysis and pattern recognition basics
plot(iris$Sepal.Length, iris$Sepal.Width, 
     col = iris$Species, 
     pch = 19, 
     main = "Iris Flower Classification Analysis",
     xlab = "Sepal Length", 
     ylab = "Sepal Width")

# Adding a visual legend to distinguish between species
legend("topright", legend = levels(iris$Species), col = 1:3, pch = 19)

print("💾 Data exploration and scatter plot generation completed successfully!")
